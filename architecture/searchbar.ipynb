    "import os\n",
    "import pandas as pd\n",
    "from langchain_openai import OpenAIEmbeddings, ChatOpenAI\n",
    "from langchain_chroma import Chroma\n",
    "from langchain_core.prompts import ChatPromptTemplate\n",
    "import ipywidgets as widgets\n",
    "from IPython.display import display, HTML\n",
    "\n",
    "# 1. RAG 로직 재검토 (OpenAI 키가 올바른지 확인 필수)\n",
    "os.environ[\"OPENAI_API_KEY\"] = os.getenv("OPENAI_API_KEY")\n",
    "\n",
    "# Vector DB 경로를 절대 경로 또는 확실한 위치로 지정\n",
    "# (scene 폴더 내에 있다면 ./chroma_db가 맞지만, 아닐 경우 상위 폴더 등 확인 필요)\n",
    "db_path = \"./chroma_db\" \n",
    "\n",
    "try:\n",
    "    embeddings = OpenAIEmbeddings()\n",
    "    vector_db = Chroma(persist_directory=db_path, embedding_function=embeddings)\n",
    "    retriever = vector_db.as_retriever(search_kwargs={\"k\": 3})\n",
    "    llm = ChatOpenAI(model=\"gpt-4o\", temperature=0.2)\n",
    "    print(\"Vector DB와 성공적으로 연결되었습니다.\")\n",
    "except Exception as e:\n",
    "    print(f\"DB 연결 중 오류 발생: {e}\")\n",
    "\n",
    "# 2. UI 구성 요소 생성 (ipywidgets 사용)\n",
    "search_input = widgets.Text(\n",
    "    placeholder='어떤 게임을 찾으시나요? (예: 타격감 좋은 FPS)',\n",
    "    layout=widgets.Layout(width='90%', height='45px')\n",
    ")\n",
    "search_button = widgets.Button(\n",
    "    description='추천받기',\n",
    "    button_style='info', # 파란색\n",
    "    layout=widgets.Layout(width='80px', height='45px')\n",
    ")\n",
    "output_area = widgets.Output(layout={'border': '1px solid #2a475e', 'padding': '10px', 'margin_top': '10px'})\n",
    "\n",
    "# 3. 실시간 답변 처리 함수\n",
    "def on_search_clicked(b):\n",
    "    query = search_input.value\n",
    "    if not query: return\n",
    "    \n",
    "    with output_area:\n",
    "        output_area.clear_output()\n",
    "        display(HTML(\"<div style='color: #66c0f4;'>AI가 리뷰를 분석하여 최고의 게임을 찾고 있습니다... 🔍</div>\"))\n",
    "        \n",
    "        try:\n",
    "            # RAG 로직 실행\n",
    "            docs = retriever.invoke(query)\n",
    "            context = \"\\n\".join([f\"[게임명: {d.metadata.get('game_name')}] {d.page_content}\" for d in docs])\n",
    "            \n",
    "            template = \"\"\"\n",
    "            검색된 리뷰를 기반으로 게임을 추천하세요. 반드시 게임명, 리뷰 원문, 추천 이유, 장점을 포함하세요.\n",
    "            Context: {context}\n",
    "            Question: {question}\n",
    "            \"\"\"\n",
    "            prompt = ChatPromptTemplate.from_template(template)\n",
    "            chain = prompt | llm\n",
    "            response = chain.invoke({\"context\": context, \"question\": query})\n",
    "            \n",
    "            # 결과 출력\n",
    "            output_area.clear_output()\n",
    "            display(HTML(f\"<div style='color: #c7d5e0; white-space: pre-wrap;'>{response.content}</div>\"))\n",
    "        except Exception as e:\n",
    "            output_area.clear_output()\n",
    "            display(HTML(f\"<div style='color: #ff4b4b;'>오류가 발생했습니다: {str(e)}</div>\"))\n",
    "\n",
    "# 이벤트 연결\n",
    "search_button.on_click(on_search_clicked)\n",
    "search_input.on_submit(lambda x: on_search_clicked(None))\n",
    "\n",
    "# 4. Steam 스타일 CSS가 적용된 최종 레이아웃 노출\n",
    "# 4. 정정된 레이아웃 코드\n",
    "# display() 대신 widgets.HTML()을 사용해야 레이아웃 안에 정상적으로 포함됩니다.\n",
    "title_widget = widgets.HTML(\"<div class='steam-title'>🔍 AI에게 여러분의 게임을 추천 받아보세요.</div>\")\n",
    "\n",
    "# CSS 스타일 적용을 위한 HTML 위젯 (화면에는 보이지 않음)\n",
    "style_widget = widgets.HTML(\"\"\"\n",
    "<style>\n",
    "    .steam-container { background-color: #171a21; padding: 20px; border-radius: 8px; border: 1px solid #2a475e; }\n",
    "    .steam-title { color: #66c0f4; font-size: 18px; font-weight: bold; margin-bottom: 10px; font-family: 'Arial'; }\n",
    "    .widget-text input { background-color: #1b2838 !important; color: white !important; border: 1px solid #2a475e !important; }\n",
    "    .ai-answer-box { color: #c7d5e0; line-height: 1.6; font-size: 14px; }\n",
    "</style>\n",
    "\"\"\")\n",
    "\n",
    "# 최종 UI 구성\n",
    "ui_layout = widgets.VBox([\n",
    "    style_widget,\n",
    "    title_widget,\n",
    "    widgets.HBox([search_input, search_button]),\n",
    "    output_area\n",
    "], layout=widgets.Layout(padding='20px', background_color='#171a21', border='1px solid #2a475e', border_radius='8px'))\n",
    "\n",
    "# 마지막에 전체 레이아웃을 한 번만 출력합니다.\n",
    "display(ui_layout)"
   ]
  }
 ],
