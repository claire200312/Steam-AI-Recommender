   "source": [
    "# AI 추천 함수 (이전 단계의 로직 그대로 사용)\n",
    "def ask_game_recommendation(query):\n",
    "    docs = retriever.invoke(query)\n",
    "    context_list = [f\"[게임명: {d.metadata.get('game_name')}] {d.page_content}\" for d in docs]\n",
    "    context = \"\\n\".join(context_list)\n",
    "    \n",
    "    template = \"\"\"\n",
    "    검색된 아래 리뷰를 기반으로 사용자의 질문에 답하세요. \n",
    "    반드시 게임명, 리뷰 원문, 추천 이유, 장점을 포함해 주세요.\n",
    "    Context: {context}\n",
    "    Question: {question}\n",
    "    \"\"\"\n",
    "    prompt = ChatPromptTemplate.from_template(template)\n",
    "    chain = prompt | llm\n",
    "    response = chain.invoke({\"context\": context, \"question\": query})\n",
    "    return response.content"
   ]
