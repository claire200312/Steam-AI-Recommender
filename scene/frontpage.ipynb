    "%%writefile steam_app.py\n",
    "import streamlit as st\n",
    "import os\n",
    "import pandas as pd\n",
    "from langchain_openai import OpenAIEmbeddings, ChatOpenAI\n",
    "from langchain_chroma import Chroma\n",
    "from langchain_core.prompts import ChatPromptTemplate\n",
    "\n",
    "# 1. 페이지 설정 (다크모드 및 타이틀)\n",
    "st.set_page_config(page_title=\"Steam AI Recommender\", layout=\"wide\")\n",
    "\n",
    "# 2. 커스텀 CSS (Steam 스타일링)\n",
    "st.markdown(\"\"\"\n",
    "<style>\n",
    "    /* 전체 배경색 */\n",
    "    .stApp {\n",
    "        background-color: #1b2838;\n",
    "        color: #c7d5e0;\n",
    "    }\n",
    "    \n",
    "    /* 헤더 스타일 */\n",
    "    .header-container {\n",
    "        background: linear-gradient(90deg, #171d25 0%, #1b2838 100%);\n",
    "        padding: 20px;\n",
    "        border-bottom: 1px solid #2a475e;\n",
    "        margin-bottom: 30px;\n",
    "    }\n",
    "    \n",
    "    /* 게임 카드 스타일 */\n",
    "    .game-card {\n",
    "        background-color: rgba(22, 32, 45, 0.8);\n",
    "        border-radius: 4px;\n",
    "        padding: 15px;\n",
    "        border: 1px solid #3d4450;\n",
    "        transition: transform 0.2s;\n",
    "        margin-bottom: 15px;\n",
    "    }\n",
    "    .game-card:hover {\n",
    "        border: 1px solid #66c0f4;\n",
    "        background-color: rgba(33, 44, 57, 0.9);\n",
    "    }\n",
    "    \n",
    "    /* 텍스트 색상 */\n",
    "    .game-title {\n",
    "        color: #ffffff;\n",
    "        font-size: 1.5rem;\n",
    "        font-weight: bold;\n",
    "        margin-bottom: 10px;\n",
    "    }\n",
    "    \n",
    "    /* 포인트 컬러 (Steam Green) */\n",
    "    .btn-recommend {\n",
    "        background-color: #a4d007;\n",
    "        color: #000000 !important;\n",
    "        border-radius: 2px;\n",
    "        font-weight: bold;\n",
    "    }\n",
    "    \n",
    "    /* 태그 스타일 */\n",
    "    .tag {\n",
    "        display: inline-block;\n",
    "        background-color: #3d4450;\n",
    "        color: #67c1f5;\n",
    "        padding: 2px 8px;\n",
    "        border-radius: 2px;\n",
    "        margin-right: 5px;\n",
    "        font-size: 0.8rem;\n",
    "    }\n",
    "</style>\n",
    "\"\"\", unsafe_allow_html=True)\n",
    "\n",
    "# 3. 백엔드 연동 설정 (API Key 및 DB)\n",
    "os.environ[\"OPENAI_API_KEY\"] = os.getenv("OPENAI_API_KEY")\n",
    "\n",
    "@st.cache_resource\n",
    "def load_rag_engine():\n",
    "    embeddings = OpenAIEmbeddings()\n",
    "    # architecture 폴더 내의 DB 참조\n",
    "    vector_db = Chroma(persist_directory=\"../architecture/chroma_db\", embedding_function=embeddings)\n",
    "    retriever = vector_db.as_retriever(search_kwargs={\"k\": 3})\n",
    "    llm = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0)\n",
    "    \n",
    "    template = \"\"\"\n",
    "    당신은 전설적인 Steam 게임 큐레이터입니다.\n",
    "    제공된 Context(리뷰)를 분석하여 사용자의 질문에 답하세요.\n",
    "    Context: {context}\n",
    "    Question: {question}\n",
    "    \n",
    "    반드시 한국어로 답하고, 게임별로 [게임명], [리뷰 요약], [추천 이유], [장점]을 명확히 구분하여 출력하세요.\n",
    "    \"\"\"\n",
    "    prompt = ChatPromptTemplate.from_template(template)\n",
    "    return retriever, llm, prompt\n",
    "\n",
    "retriever, llm, prompt = load_rag_engine()\n",
    "\n",
    "# 4. 메인 UI\n",
    "st.markdown('<div class=\"header-container\"><h1>STEAM <span style=\"color:#66c0f4\">AI 추천 가이드</span></h1></div>', unsafe_allow_html=True)\n",
    "\n",
    "with st.container():\n",
    "    st.write(\"### 어떤 게임을 찾으시나요?\")\n",
    "    query = st.text_input(\"예: 친구들과 함께할 수 있는 생존 FPS 게임 추천해줘\", placeholder=\"검색어를 입력하세요...\")\n",
    "    \n",
    "    if query:\n",
    "        with st.spinner(\"Steam DB를 탐색 중입니다...\"):\n",
    "            # RAG 프로세스 실행\n",
    "            docs = retriever.invoke(query)\n",
    "            context_list = []\n",
    "            for d in docs:\n",
    "                game_name = d.metadata.get('game_name', '알 수 없음')\n",
    "                context_list.append(f\"[게임명: {game_name}] {d.page_content}\")\n",
    "            \n",
    "            chain = prompt | llm\n",
    "            response = chain.invoke({\"context\": \"\\n\".join(context_list), \"question\": query})\n",
    "            \n",
    "            # 결과 파싱 및 디자인 적용 출력 (간단하게 텍스트만 보여주되 스타일 적용)\n",
    "            st.markdown(\"--- \")\n",
    "            st.markdown(f\"### 🎮 추천된 게임 리스트\")\n",
    "            \n",
    "            # 가공된 텍스트를 카드 형태로 출력 (llm 답변을 구조화하여 처리하는 로직 필요)\n",
    "            st.markdown(f'''\n",
    "            <div class=\"game-card\">\n",
    "                <div class=\"game-title\">추천 결과</div>\n",
    "                <div style=\"white-space: pre-wrap;\">{response.content}</div>\n",
    "            </div>\n",
    "            ''', unsafe_allow_html=True)\n",
    "\n",
    "st.sidebar.markdown(\"\"\"\n",
    "### 🔍 검색 필터\n",
    "- **장르**: 액션, 어드벤처, RPG\n",
    "- **플레이**: 싱글 플레이어, 협동\n",
    "--- \n",
    "**Steam AI v1.0**\n",
    "\"\"\")\n"
   ]
  }
 ],
